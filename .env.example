# Database
DATABASE_URL=postgresql://alphaplus:alphaplus@db:5432/alphaplus
POSTGRES_DB=alphaplus
POSTGRES_USER=alphaplus
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_URL=redis://redis:6379/0

# Google Cloud Storage
GCS_BUCKET=your-gcs-bucket-name
GCS_PROJECT=your-gcp-project-id

# Google Application Credentials
# Option A: Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json
# Option B: Set GOOGLE_APPLICATION_CREDENTIALS env var on the host

# GCP Compute Engine (for GPU VM lifecycle)
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-a
GPU_VM_NAME=alphaplus-trainer

# CORS and Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# MENTAT integration — add MENTAT's IP/URL so it can call this API cross-origin
# Comma-separated. Example: http://34.72.10.5,https://mentat.internal
MENTAT_ORIGINS=http://MENTAT_IP_HERE

# Upload limits (in bytes)
MAX_UPLOAD_SIZE_BYTES=21474836480
MIN_UPLOAD_SIZE_BYTES=10485760

# Extraction scratch disk path (mount from persistent disk in production)
EXTRACTION_PATH=/data/extraction
